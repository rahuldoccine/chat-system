NODE_ENV=development
PORT=4000
HOST=0.0.0.0
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/mernchat

# Access JWT: prefer JWT_ACCESS_SECRET; legacy JWT_SECRET still works
JWT_ACCESS_SECRET=change-me-access-secret-min-16-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-16-chars
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_DAYS=30
PASSWORD_RESET_TOKEN_TTL_MINUTES=60
BCRYPT_ROUNDS=12

# Used in password-reset email links
FRONTEND_URL=http://localhost:5173

# HttpOnly cookie name for refresh token (path=/api/v1/auth). Clients may also send refreshToken in JSON body for mobile/API tools.
REFRESH_COOKIE_NAME=refresh_token

# Optional SMTP (if unset, forgot-password still returns 200 but no email is sent - see logs)
# Gmail: enable 2FA, create an App Password, use it here without quotes around the value.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# Comma-separated; include LAN dev URL when testing from other devices (see frontend .env.example)
CORS_ORIGIN=http://localhost:5173
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=50
LOG_LEVEL=info

# Swagger UI at http://localhost:4000/api/docs - on by default in development; set to "true" in production if desired
ENABLE_SWAGGER=

# OpenAPI "Try it out" server URL (production), e.g. https://your-service.up.railway.app/api/v1
PUBLIC_API_URL=

# Rate limits (optional overrides)
AUTH_LOGIN_WINDOW_MS=900000
AUTH_LOGIN_MAX=20
AUTH_FORGOT_WINDOW_MS=900000
AUTH_FORGOT_MAX=5
AUTH_REFRESH_WINDOW_MS=900000
AUTH_REFRESH_MAX=60

# Reconnect delivery flush tuning (for offline backlog catch-up at scale)
# CHAT_RECONNECT_DELIVERY_PAGE_SIZE=1000
# CHAT_RECONNECT_DELIVERY_SYNC_BUDGET_MS=250
# CHAT_RECONNECT_DELIVERY_MAX_ASYNC_PASSES=20

# Optional: Redis for Socket.IO multi-node fan-out (`@socket.io/redis-adapter`) and short TTL presence keys
# for cross-node "user online" (push suppression). Leave unset for single-node in-memory presence only.
# REDIS_URL=redis://127.0.0.1:6379

# Optional: Firebase Cloud Messaging - push is skipped when either value is unset.
# FCM_PROJECT_ID=your-gcp-project-id
# FCM_SERVICE_ACCOUNT_PATH=./secrets/firebase-adminsdk.json

# Optional: Web Push (VAPID). When set with all three, WEB device tokens are delivered via `web-push`.
# Generate keys: `npx web-push generate-vapid-keys`
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:support@example.com

# Uploads: `MAX_UPLOAD_MB` caps size. Orphan disk files (no `UploadedFile` row) are not auto-deleted;
# periodically compare `UPLOAD_DIR` to the DB or run a maintenance script (see `scripts/cleanup-orphan-uploads.mjs`).