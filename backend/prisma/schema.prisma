generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Auth (Sprint 2) ---

model User {
  id           String @id @default(uuid())
  email        String @unique
  passwordHash String

  /// Profile
  displayName String?
  username    String? @unique
  avatarUrl   String?

  emailVerifiedAt DateTime?
  /// Bumped on logout-all / password reset; must match JWT `authVer` claim.
  authVersion Int @default(0)
  /// Platform moderator: can review user reports in Settings.
  isAdmin     Boolean   @default(false)
  isOnline    Boolean   @default(false)
  lastSeenAt  DateTime?
  deletedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshSessions     RefreshSession[]
  passwordResetTokens PasswordResetToken[]
  chatsCreated        Chat[]               @relation("ChatCreatedBy")
  chatMemberships     ChatMember[]
  messagesSent        Message[]            @relation("MessageSender")
  receipts            Receipt[]
  reactions           Reaction[]
  friendsAsRequester  Friend[]             @relation("FriendRequester")
  friendsAsAddressee  Friend[]             @relation("FriendAddressee")
  blocksIssued        Block[]              @relation("BlockBlocker")
  blocksReceived      Block[]              @relation("BlockBlocked")
  reportsFiled        Report[]             @relation("ReportReporter")
  reportsAgainst      Report[]             @relation("ReportTargetUser")
  pollsCreated        Poll[]               @relation("PollCreatedBy")
  pollVotes           PollVote[]
  callLogsAsInitiator CallLog[]            @relation("CallInitiator")
  callLogsAsPeer      CallLog[]            @relation("CallPeer")
  deviceTokens        DeviceToken[]
  userSettings        UserSettings?
  pinnedMessages      PinnedMessage[]      @relation("PinnedByUser")
  uploadedFiles       UploadedFile[]
}

model RefreshSession {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  userAgent  String?
  ipLast     String?
  revokedAt  DateTime?

  @@index([userId, expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  usedAt    DateTime?

  @@index([userId])
}

// --- Chat domain (Sprint 3) ---

enum ChatType {
  DIRECT
  GROUP
}

enum ChatMemberRole {
  OWNER
  ADMIN
  MOD
  MEMBER
}

enum GroupVisibility {
  PRIVATE
  PUBLIC
}

/// Direct chats: set `dmKey` to a stable canonical key (e.g. sorted user ids joined by ":") - @@unique prevents duplicate DMs. Null for GROUP.
model Chat {
  id        String   @id @default(uuid())
  type      ChatType
  dmKey     String?  @unique
  title     String?
  avatarUrl String?
  groupVisibility  GroupVisibility  @default(PRIVATE)

  createdById String
  createdBy   User   @relation("ChatCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  lastMessageAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members        ChatMember[]
  messages       Message[]
  polls          Poll[]
  reports        Report[]
  callLogs       CallLog[]
  pinnedMessages PinnedMessage[]
  uploadedFiles  UploadedFile[]

  @@index([updatedAt])
  @@index([lastMessageAt])
}

model ChatMember {
  id     String @id @default(uuid())
  chatId String
  chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role         ChatMemberRole @default(MEMBER)
  joinedAt     DateTime       @default(now())
  mutedUntil   DateTime?
  pinnedAt     DateTime?
  favoritedAt  DateTime?
  closedAt     DateTime?
  leftAt       DateTime?

  @@unique([chatId, userId])
  @@index([userId, leftAt])
}

enum MessageKind {
  TEXT
  IMAGE
  FILE
  SYSTEM
  POLL
  OTHER
}

model Message {
  id       String @id @default(uuid())
  chatId   String
  chat     Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  senderId String
  sender   User   @relation("MessageSender", fields: [senderId], references: [id], onDelete: Restrict)

  /// Idempotency: same client id cannot be inserted twice per chat
  clientMessageId String
  kind            MessageKind @default(TEXT)

  ciphertext  String? @db.Text
  contentMeta Json?

  replyToId String?
  replyTo   Message?  @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   Message[] @relation("MessageReplies")

  /// Slack-style thread: all replies share the root message id (null = top-level / root).
  threadRootId String?
  threadRoot   Message?  @relation("MessageThread", fields: [threadRootId], references: [id], onDelete: SetNull)
  threadReplies Message[] @relation("MessageThread")

  /// When true, a thread reply is also shown in the main DM timeline.
  broadcastToChannel Boolean @default(false)

  /// Denormalized on root messages only (threadRootId is null).
  threadReplyCount   Int       @default(0)
  threadLastReplyAt  DateTime?

  editedAt  DateTime?
  deletedAt DateTime?

  createdAt DateTime @default(now())

  receipts      Receipt[]
  reactions     Reaction[]
  reports       Report[]
  poll          Poll?
  pinnedInChats PinnedMessage[]
  uploadedFiles UploadedFile[]

  @@unique([chatId, clientMessageId])
  @@index([chatId, createdAt(sort: Desc)])
  @@index([senderId, createdAt])
  @@index([chatId, threadRootId, createdAt])
}

/// Per-user delivery/read state for a message.
/// Receipt strategy: **eager** - create one row per (message, recipient) at send time for predictable unread math.
/// Alternative **lazy**: create rows on first delivery/read (document if you switch later).
model Receipt {
  id        String  @id @default(uuid())
  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  deliveredAt DateTime?
  readAt      DateTime?

  @@unique([messageId, userId])
  @@index([userId, readAt])
}

model Reaction {
  id        String  @id @default(uuid())
  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  emoji     String
  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

enum FriendStatus {
  PENDING
  ACCEPTED
  REJECTED
}

/// `pairKey` = canonical sorted pair key (e.g. `${min(id1,id2)}:${max(id1,id2)}`) - prevents duplicate friend edges.
model Friend {
  id          String       @id @default(uuid())
  pairKey     String       @unique
  requesterId String
  requester   User         @relation("FriendRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addresseeId String
  addressee   User         @relation("FriendAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)
  status      FriendStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  respondedAt DateTime?

  @@index([requesterId])
  @@index([addresseeId])
}

model Block {
  id        String   @id @default(uuid())
  blockerId String
  blocker   User     @relation("BlockBlocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User     @relation("BlockBlocked", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

enum ReportStatus {
  OPEN
  REVIEWED
  DISMISSED
  ACTIONED
}

model Report {
  id         String @id @default(uuid())
  reporterId String
  reporter   User   @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)

  targetUserId String?
  targetUser   User?   @relation("ReportTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)

  targetMessageId String?
  targetMessage   Message? @relation(fields: [targetMessageId], references: [id], onDelete: SetNull)

  chatId String?
  chat   Chat?   @relation(fields: [chatId], references: [id], onDelete: SetNull)

  reason     String
  details    String?      @db.Text
  status     ReportStatus @default(OPEN)
  createdAt  DateTime     @default(now())
  reviewedAt DateTime?

  @@index([status, createdAt])
}

model Poll {
  id        String   @id @default(uuid())
  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  messageId String?  @unique
  message   Message? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  question    String
  closesAt    DateTime?
  createdById String
  createdBy   User      @relation("PollCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime  @default(now())

  options PollOption[]
  votes   PollVote[]
}

model PollOption {
  id        String @id @default(uuid())
  pollId    String
  poll      Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)
  label     String
  sortOrder Int    @default(0)

  votes PollVote[]

  @@index([pollId, sortOrder])
}

model PollVote {
  id           String     @id @default(uuid())
  pollId       String
  poll         Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  pollOptionId String
  pollOption   PollOption @relation(fields: [pollOptionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([pollId, userId])
}

enum CallKind {
  AUDIO
  VIDEO
}

enum CallStatus {
  INITIATED
  RINGING
  CONNECTED
  COMPLETED
  MISSED
  FAILED
}

model CallLog {
  id          String  @id @default(uuid())
  chatId      String?
  chat        Chat?   @relation(fields: [chatId], references: [id], onDelete: SetNull)
  initiatorId String
  initiator   User    @relation("CallInitiator", fields: [initiatorId], references: [id], onDelete: Cascade)
  peerId      String?
  peer        User?   @relation("CallPeer", fields: [peerId], references: [id], onDelete: SetNull)

  kind      CallKind   @default(AUDIO)
  status    CallStatus @default(INITIATED)
  startedAt DateTime   @default(now())
  endedAt   DateTime?
  metadata  Json?

  @@index([initiatorId, startedAt])
  @@index([chatId, startedAt])
}

enum DevicePlatform {
  IOS
  ANDROID
  WEB
  UNKNOWN
}

model DeviceToken {
  id         String         @id @default(uuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  token      String         @unique
  platform   DevicePlatform @default(UNKNOWN)
  createdAt  DateTime       @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?

  @@index([userId])
}

model UserSettings {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  notifyPush       Boolean @default(true)
  notifyEmail      Boolean @default(true)
  showReadReceipts Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PinnedMessage {
  id         String   @id @default(uuid())
  chatId     String
  chat       Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  messageId  String
  message    Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  pinnedById String
  pinnedBy   User     @relation("PinnedByUser", fields: [pinnedById], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([chatId, messageId])
  @@index([chatId])
}

enum UploadFileKind {
  IMAGE
  DOCUMENT
  AUDIO
  VIDEO
  VOICE
  OTHER
}

model UploadedFile {
  id         String          @id @default(uuid())
  userId     String
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatId     String?
  chat       Chat?           @relation(fields: [chatId], references: [id], onDelete: SetNull)
  messageId  String?
  message    Message?        @relation(fields: [messageId], references: [id], onDelete: SetNull)
  storageKey String          @unique
  mimeType   String
  size       Int
  kind       UploadFileKind?
  createdAt  DateTime        @default(now())

  @@index([userId])
  @@index([chatId])
  @@index([messageId])
}
