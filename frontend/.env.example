# Copy this file to .env and adjust values for your machine.

# REST API (axios)
VITE_API_URL=http://localhost:4000/api/v1

# Web Push: configure VAPID keys on the API server (see backend .env).
# Users enable push in Settings → Privacy; requires HTTPS or localhost.

# Socket.IO (defaults to same host as API if omitted)
VITE_SOCKET_URL=http://localhost:4000

# Uploaded files path on API (appended to api origin)
VITE_FILES_API_PATH=/api/v1/files

# GIF picker - https://developers.giphy.com/dashboard/
VITE_GIPHY_API_KEY=
VITE_GIPHY_API_BASE=https://api.giphy.com/v1/gifs
VITE_GIPHY_SEARCH_LIMIT=100
# hd = original GIF (best), balanced = under 8MB, fast = smaller / quicker
VITE_GIPHY_DOWNLOAD_QUALITY=hd
# Skip original if larger than this (MB); uses downsized_large instead
VITE_GIPHY_MAX_DOWNLOAD_MB=8

# Dev-only: [MS:scroll] debug logs (1 = on, 0 = off)
VITE_SCROLL_DEBUG=1

# Composer attachments
VITE_MAX_ATTACHMENTS=10
VITE_MAX_UPLOAD_MB=50
VITE_ALLOWED_FILE_EXTENSIONS=.jpg,.jpeg,.png,.gif,.pdf,.xls,.xlsx,.csv,.docx,.mp4,.webm,.mov,.mp3,.m4a,.wav,.ogg,.aac

# WebRTC ICE (calls)
# Comma-separated STUN URLs; default public STUN if omitted
VITE_STUN_URL=stun:stun.l.google.com:19302
# Optional TURN (coturn) - required for many NAT/mobile networks
# VITE_TURN_URL=turn:localhost:3478
# VITE_TURN_USERNAME=chatuser
# VITE_TURN_CREDENTIAL=your-turn-password
